# Smart City AI Agent - Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env  (or on Windows: copy day1_env_example .env)

# ── App Settings ──────────────────────────────────────────
APP_NAME=Smart City AI Agent
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ── TfL API (optional - works without key, key gives higher rate limits) ──
# Register at: https://api-portal.tfl.gov.uk/
TFL_APP_KEY=

# ── TomTom API (Day 3 - sign up at developer.tomtom.com) ──
TOMTOM_API_KEY=

# ── Google Gemini (Day 4) ─────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Cache Settings ────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── HTTP Client ───────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=2
